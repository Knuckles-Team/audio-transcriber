{
  "mcpServers": {
    "audio-transcriber": {
      "command": "uv",
      "args": [
        "run",
        "audio-transcriber-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "AUDIO_PROCESSINGTOOL": "True",
        "MISCTOOL": "True",
        "WHISPER_MODEL": "base"
      }
    }
  }
}
