{
  "mcpServers": {
    "audio-transcriber": {
      "command": "uv",
      "args": [
        "run",
        "audio-transcriber-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "AUDIO_PROCESSINGTOOL": "True",
        "TRANSCRIBE_DIRECTORY": "<YOUR_TRANSCRIBE_DIRECTORY>",
        "WHISPER_MODEL": "<YOUR_WHISPER_MODEL>"
      }
    }
  }
}
